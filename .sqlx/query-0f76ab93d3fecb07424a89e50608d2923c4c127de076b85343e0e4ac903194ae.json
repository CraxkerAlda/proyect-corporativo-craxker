  "query": "\n        SELECT u.id, u.strnombreusuario, u.strcorreo, u.strnumerocelular, \n               u.strimagenpath, p.strnombreperfil\n        FROM usuarios u\n        JOIN perfiles p ON u.idperfil = p.id\n        ORDER BY u.id DESC\n        ",
